<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="vessel_v1">
    <link name="base_link">
      
      <inertial>
        <mass>350.0</mass>
        <pose> -0.08 0 0 0 0 0</pose>
        <inertia>
          <ixx>15.0</ixx> <iyy>125.0</iyy> <izz>125.0</izz>
          <ixy>0.0</ixy> <ixz>0.0</ixz> <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="collision_cylinder">
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.3</radius>
            <length>2.0</length>
          </cylinder>
        </geometry>
      </collision>

      <collision name="collision_cone">
        <pose>1.625 0 0 0 1.5708 0</pose>
        <geometry>
          <cone>
            <radius>0.3</radius>
            <length>1.25</length>
          </cone>
        </geometry>
      </collision>

      <visual name="visual_cylinder">
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.3</radius>
            <length>2.0</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1.0</ambient>
          <diffuse>1.0 0.0 0.0 1.0</diffuse>
        </material>
      </visual>

      <visual name="visual_cone">
        <pose>1.625 0 0 0 1.5708 0</pose>
        <geometry>
          <cone>
            <radius>0.3</radius>
            <length>1.25</length>
          </cone>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1.0</ambient>
          <diffuse>1.0 0.0 0.0 1.0</diffuse>
        </material>
      </visual>

    </link>

    <link name="left_propeller">
      <pose>-1.1 0.2 -0.2 0 1.5708 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <visual name="left_prop_visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <link name="right_propeller">
      <pose>-1.1 -0.2 -0.2 0 1.5708 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia>
      </inertial>
      <visual name="right_prop_visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <joint name="left_engine_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_propeller</child>
      <axis>
        <xyz>0 0 1</xyz> </axis>
    </joint>

    <joint name="right_engine_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_propeller</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>
    
    <plugin filename="gz-sim-hydrodynamics-system" name="gz::sim::systems::Hydrodynamics">
      <!-- forza su su x.y.z -->
      <link_name>base_link</link_name>
      <xU>-51.3</xU>
    <xAbsU>-72.4</xAbsU> 
      <yV>-40.0</yV>
      <yAbsV>0.0</yAbsV>
      <zW>-500.0</zW>
      <!-- momento frenante su x.y.z, linear dumping: basse velocità-->
      <kP>-50.0</kP>
      <mQ>-50.0.0</mQ>
      <nR>-400.0</nR>
      <!-- smorzamento quadratico, damping-drag: alte vleocità -->
      <!-- <xUU>, <yVV>, <zWW>, <kPP>, <mQQ>, <nRR> -->
    </plugin>

    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <publish_nested_model_pose>true</publish_nested_model_pose>
      <update_frequency>50</update_frequency> 
    </plugin>

    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <namespace>vessel_v1</namespace>
      <joint_name>left_engine_joint</joint_name>
      <thrust_coefficient>0.02</thrust_coefficient>
      <fluid_density>1025.0</fluid_density>
      <propeller_diameter>0.2</propeller_diameter>
    </plugin>

    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <namespace>vessel_v1</namespace>
      <joint_name>right_engine_joint</joint_name>
      <thrust_coefficient>0.02</thrust_coefficient>
      <fluid_density>1025.0</fluid_density>
      <propeller_diameter>0.2</propeller_diameter>
    </plugin>

  </model>
</sdf>