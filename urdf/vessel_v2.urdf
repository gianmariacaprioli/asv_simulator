<?xml version="1.0" ?>
<robot name="vessel_v2">

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 -0.98" rpy="0 0 0"/>
      <mass value="55000.0"/>
      <inertia ixx="146366.0" ixy="0.0000001" ixz="0.0000001" iyy="805620.0" iyz="0.0000001" izz="913838.0"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="13.11 5.27 2.04"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="-2.5 0 0.78" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/root/ros2_ws/src/asv_simulator/models/vessel_v2/meshes/vessel_simplified.stl" scale="0.0556 0.0556 0.0556"/>
      </geometry>
    </visual>
  </link>

  <link name="left_propeller">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.000000001" ixz="0.0000000001" iyy="0.001" iyz="0.0000000001" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 3.14"/>
      <geometry>
        <mesh filename="package://asv_simulator/models/vessel_v2/meshes/vessel_propeller_simplified.stl" scale="0.1 0.1 0.1"/>
      </geometry>
    </visual>
  </link>

  <link name="right_propeller">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.000000001" ixz="0.0000000001" iyy="0.001" iyz="0.0000000001" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0.0 3.14"/>
      <geometry>
        <mesh filename="package://asv_simulator/models/vessel_v2/meshes/vessel_propeller_simplified.stl" scale="0.1 0.1 0.1"/>
      </geometry>
    </visual>
  </link>

  <link name="gps_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.000000001" ixz="0.0000000001" iyy="0.001" iyz="0.0000000001" izz="0.001"/>
    </inertial>
  </link>

  <link name="sonar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.000000001" ixz="0.0000000001" iyy="0.001" iyz="0.0000000001" izz="0.001"/>
    </inertial>
  </link>

  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.001" ixy="0.000000001" ixz="0.0000000001" iyy="0.001" iyz="0.0000000001" izz="0.001"/>
    </inertial>
  </link>

  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.001" ixy="0.000000001" ixz="0.0000000001" iyy="0.001" iyz="0.0000000001" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_engine_joint" type="revolute">
    <origin xyz="-6.6 -1.0 -0.8" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_propeller"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1e16" upper="1e16" effort="1e9" velocity="10000"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="right_engine_joint" type="revolute">
    <origin xyz="-6.6 1.0 -0.8" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_propeller"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1e16" upper="1e16" effort="1e9" velocity="10000"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="gps_joint" type="fixed">
    <origin xyz="-3.0 0 2.5" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="gps_link"/>
  </joint>

  <joint name="sonar_joint" type="fixed">
    <origin xyz="8.0 0 -2.5" rpy="0 1.57 0"/>
    <parent link="base_link"/>
    <child link="sonar_link"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <origin xyz="6.0 0 1.8" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

<joint name="lidar_joint" type="fixed">
    <origin xyz="6.0 0 1.2" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
  </joint>

  <gazebo reference="base_link">
    <visual>
      <material>
        <ambient>0.2 0.2 0.8 1.0</ambient>
        <diffuse>0.2 0.2 0.8 1.0</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="left_propeller">
    <visual>
      <material>
        <ambient>0.2 0.2 0.8 1.0</ambient>
        <diffuse>0.2 0.2 0.8 1.0</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="right_propeller">
    <visual>
      <material>
        <ambient>0.2 0.2 0.8 1.0</ambient>
        <diffuse>0.2 0.2 0.8 1.0</diffuse>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="gps_link">
    <sensor name="gps_sensor" type="navsat">
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <topic>/vessel_v2/gps/fix</topic>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <pose>0 0 0.2 0 0 0</pose>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>/vessel_v2/camera</topic>
      <camera>
        <horizontal_fov>1.396</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>150</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0.7 0 0 0</pose>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>/vessel_v2/lidar</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-1.57</min_angle>
            <max_angle>1.57</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261</min_angle>
            <max_angle>0.261</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.5</min>
          <max>100.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <!-- <gazebo reference="sonar_link">
    <sensor name="sonar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>/vessel_v2/lidar</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.261</min_angle>
            <max_angle>0.261</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.5</min>
          <max>100.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo> -->

  <gazebo reference="sonar_link">
    <sensor name="sonar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <update_rate>5</update_rate>
      <topic>/vessel_v2/sonar</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>32</samples>
            <resolution>1</resolution>
            <min_angle>-0.349</min_angle>
            <max_angle>0.349</max_angle>
          </horizontal>
          <vertical>
            <samples>32</samples>
            <resolution>1</resolution>
            <min_angle>-0.349</min_angle>
            <max_angle>0.349</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.5</min>
          <max>500.0</max>
          <resolution>0.1</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>


  <gazebo>
    <plugin filename="gz-sim-hydrodynamics-system" name="gz::sim::systems::Hydrodynamics">
      <link_name>base_link</link_name>
      <xU>-2750.0</xU>
      <xUabsU>-1500.0</xUabsU>
      <yV>-5500.0</yV>
      <yVabsV>-4028.0</yVabsV>
      <zW>-5500.0</zW>
      <zWabsW>-15000.0</zWabsW>
      <kP>-14636.0</kP>
      <kPabsP>-100000.0</kPabsP>
      <mQ>-80562.0</mQ>
      <mQabsQ>-200000.0</mQabsQ>
      <nR>-60922.0</nR>
      <nRabsR>-283000.0</nRabsR>
    </plugin>

    <!-- <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <update_frequency>50</update_frequency>
    </plugin> -->

    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_publish_frequency>50</odom_publish_frequency>
      <dimensions>3</dimensions>
    </plugin>

    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <namespace>vessel_v2</namespace>
      <joint_name>left_engine_joint</joint_name>
      <max_thrust_cmd>30000.0</max_thrust_cmd>
      <min_thrust_cmd>-20000.0</min_thrust_cmd>
      <thrust_coefficient>0.0126</thrust_coefficient>
      <velocity_control>false</velocity_control>
      <fluid_density>1025.0</fluid_density>
      <propeller_diameter>1.2</propeller_diameter>
    </plugin>

    <plugin filename="gz-sim-thruster-system" name="gz::sim::systems::Thruster">
      <namespace>vessel_v2</namespace>
      <joint_name>right_engine_joint</joint_name>
      <max_thrust_cmd>30000.0</max_thrust_cmd>
      <min_thrust_cmd>-20000.0</min_thrust_cmd>
      <velocity_control>false</velocity_control>
      <thrust_coefficient>0.0126</thrust_coefficient>
      <fluid_density>1025.0</fluid_density>
      <propeller_diameter>1.2</propeller_diameter>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>
  </gazebo>

</robot>